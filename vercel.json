{
  "version": 2,
  "builds": [
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/assets/icon.png"
    },
    {
      "src": "/favicon.png",
      "dest": "/assets/icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}

